  <!-- ============================================================ -->
  <!-- BASE LINK                                                     -->
  <!-- ============================================================ -->
  <link name="base_link">
    <inertial>
      <origin xyz="-0.16542560919261 -0.149974396919816 0.0555112241124055" rpy="0 0 0"/>
      <mass value="2.23789814285683"/>
      <inertia ixx="0.0100668608395496" ixy="3.41741618462473E-05" ixz="8.32772399082271E-05"
               iyy="0.0114849385643874" iyz="8.93952677484501E-05" izz="0.0190387521155491"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://audix/meshes/base_link.STL"/></geometry>
      <material name=""><color rgba="0.792 0.820 0.933 1"/></material>
    </visual>
    <!-- dartsim does not support mesh collision — use box approximation -->
    <collision>
      <origin xyz="-0.165 -0.150 0.055" rpy="0 0 0"/>
      <geometry><box size="0.32 0.35 0.11"/></geometry>
    </collision>
  </link>

  <!-- RobotBody frame — used as base_frame_id in controllers/EKF -->
  <link name="RobotBody"/>
  <joint name="robot_body_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 3.14159"/>
    <parent link="base_link"/>
    <child link="RobotBody"/>
  </joint>

