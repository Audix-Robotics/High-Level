  <link name="top_stud_link">
    <inertial><origin xyz="-7.501E-08 -7.194E-07 -1.618E-06" rpy="0 0 0"/><mass value="0.001371"/>
      <inertia ixx="1.363E-06" ixy="1.136E-11" ixz="-2.262E-13" iyy="2.721E-09" iyz="0" izz="1.363E-06"/></inertial>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><mesh filename="package://audix/meshes/top_stud_link.STL"/></geometry><material name=""><color rgba="0.776 0.757 0.737 1"/></material></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/><geometry><cylinder radius="0.004" length="0.015"/></geometry></collision>
  </link>
  <joint name="top_stud_joint" type="prismatic">
    <origin xyz="0.117801346067551 0.022856657474836 -0.0371507194079034" rpy="-1.5707963267949 0 1.5707963267949"/>
    <parent link="left_link6"/><child link="top_stud_link"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.05" upper="0.05" effort="150" velocity="0.15"/>
  </joint>

  <!-- ============================================================ -->
  <!-- SENSOR FRAMES                                                 -->
  <!-- ============================================================ -->

  <!-- IR Sensors (from user's updated URDF) -->
  <link name="ir_back_link"/>
  <joint name="ir_back_joint" type="fixed">
    <origin xyz="0.00389 -0.15402 0.01325" rpy="0 1.5707963267949 0"/>
    <parent link="base_link"/><child link="ir_back_link"/>
  </joint>

  <link name="ir_right_link"/>
  <joint name="ir_right_joint" type="fixed">
    <origin xyz="-0.15593 0.00425 0.01325" rpy="0 1.5707963267949 1.5707963267949"/>
    <parent link="base_link"/><child link="ir_right_link"/>
  </joint>

  <link name="ir_front_right_link"/>
  <joint name="ir_front_right_joint" type="fixed">
    <origin xyz="-0.33619 -0.02391 0.01325" rpy="0 1.5707963267949 2.3561944901923"/>
    <parent link="base_link"/><child link="ir_front_right_link"/>
  </joint>

  <link name="ir_front_link"/>
  <joint name="ir_front_joint" type="fixed">
    <origin xyz="-0.36061 -0.14597 0.01325" rpy="0 1.5707963267949 3.1415926535898"/>
    <parent link="base_link"/><child link="ir_front_link"/>
  </joint>

  <link name="ir_front_left_link"/>
  <joint name="ir_front_left_joint" type="fixed">
    <origin xyz="-0.34189 -0.27041 0.01325" rpy="0 1.5707963267949 -2.3561944901923"/>
    <parent link="base_link"/><child link="ir_front_left_link"/>
  </joint>

  <link name="ir_left_link"/>
  <joint name="ir_left_joint" type="fixed">
    <origin xyz="-0.16403 -0.30425 0.01325" rpy="0 1.5707963267949 -1.5707963267949"/>
    <parent link="base_link"/><child link="ir_left_link"/>
  </joint>

  <!-- Camera Optical Frame -->
  <link name="camera_optical_link"/>
  <joint name="camera_optical_joint" type="fixed">
    <origin xyz="-0.0285214690324131 0.0532714690323321 -0.0320399999999404" rpy="-1.5707963267949 0 -1.57079632679491"/>
    <parent link="camera_link"/><child link="camera_optical_link"/>
  </joint>

  <!-- IMU Frame -->
  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <origin xyz="-0.15866 -0.15079 0.010" rpy="0 0 0"/>
    <parent link="base_link"/><child link="imu_link"/>
  </joint>

  <!-- ============================================================ -->
  <!-- ros2_control — wheels (velocity) + scissor joints (position) -->
  <!-- ============================================================ -->
  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <!-- Wheels — velocity controlled -->
    <joint name="front_left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>
    <joint name="front_right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>
    <joint name="back_left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>
    <joint name="back_right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>
    <!-- Scissor lift — all position controlled -->
    <joint name="bottom_stud_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="right_joint1"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="right_joint2"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="right_joint3"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="right_joint4"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="right_joint5"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="right_joint6"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="left_joint1"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="left_joint2"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="left_joint3"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="left_joint4"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="left_joint5"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="left_joint6"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="camera_joint"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
    <joint name="top_stud_joint"><command_interface name="position"/><state_interface name="position"/><state_interface name="velocity"/></joint>
  </ros2_control>

  <!-- ============================================================ -->
  <!-- Gazebo plugins                                                -->
  <!-- ============================================================ -->
  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(arg controllers_yaml)</parameters>
      <ros><remapping>~/robot_description:=robot_description</remapping></ros>
    </plugin>
  </gazebo>

  <!-- Wheel friction -->
  <gazebo reference="front_left_wheel_link"><mu1>1.0</mu1><mu2>1.0</mu2></gazebo>
  <gazebo reference="front_right_wheel_link"><mu1>1.0</mu1><mu2>1.0</mu2></gazebo>
  <gazebo reference="back_left_wheel_link"><mu1>1.0</mu1><mu2>1.0</mu2></gazebo>
  <gazebo reference="back_right_wheel_link"><mu1>1.0</mu1><mu2>1.0</mu2></gazebo>

  <!-- IMU sensor -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <pose>0 0 0 0 0 0</pose>
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <topic>/imu</topic>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.009</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.009</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.009</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0.0</mean><stddev>0.021</stddev></noise></x>
          <y><noise type="gaussian"><mean>0.0</mean><stddev>0.021</stddev></noise></y>
          <z><noise type="gaussian"><mean>0.0</mean><stddev>0.021</stddev></noise></z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>

  <!-- 6x IR sensors as gpu_lidar (35deg FOV, 0.30m range) -->
  <gazebo reference="ir_back_link">
    <sensor name="ir_back" type="gpu_lidar">
      <pose>0 0 0 0 -1.5707963267949 0</pose>
      <always_on>true</always_on><update_rate>10</update_rate><topic>/ir_back/scan</topic>
      <lidar><scan><horizontal><samples>10</samples><resolution>1</resolution><min_angle>-0.30543</min_angle><max_angle>0.30543</max_angle></horizontal><vertical><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></vertical></scan><range><min>0.05</min><max>0.30</max><resolution>0.01</resolution></range><noise><type>gaussian</type><mean>0.0</mean><stddev>0.005</stddev></noise></lidar>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <gazebo reference="ir_right_link">
    <sensor name="ir_right" type="gpu_lidar">
      <pose>0 0 0 0 -1.5707963267949 0</pose>
      <always_on>true</always_on><update_rate>10</update_rate><topic>/ir_right/scan</topic>
      <lidar><scan><horizontal><samples>10</samples><resolution>1</resolution><min_angle>-0.30543</min_angle><max_angle>0.30543</max_angle></horizontal><vertical><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></vertical></scan><range><min>0.05</min><max>0.30</max><resolution>0.01</resolution></range><noise><type>gaussian</type><mean>0.0</mean><stddev>0.005</stddev></noise></lidar>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <gazebo reference="ir_front_right_link">
    <sensor name="ir_front_right" type="gpu_lidar">
      <pose>0 0 0 0 -1.5707963267949 0</pose>
      <always_on>true</always_on><update_rate>10</update_rate><topic>/ir_front_right/scan</topic>
      <lidar><scan><horizontal><samples>10</samples><resolution>1</resolution><min_angle>-0.30543</min_angle><max_angle>0.30543</max_angle></horizontal><vertical><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></vertical></scan><range><min>0.05</min><max>0.30</max><resolution>0.01</resolution></range><noise><type>gaussian</type><mean>0.0</mean><stddev>0.005</stddev></noise></lidar>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <gazebo reference="ir_front_link">
    <sensor name="ir_front" type="gpu_lidar">
      <pose>0 0 0 0 -1.5707963267949 0</pose>
      <always_on>true</always_on><update_rate>10</update_rate><topic>/ir_front/scan</topic>
      <lidar><scan><horizontal><samples>10</samples><resolution>1</resolution><min_angle>-0.30543</min_angle><max_angle>0.30543</max_angle></horizontal><vertical><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></vertical></scan><range><min>0.05</min><max>0.30</max><resolution>0.01</resolution></range><noise><type>gaussian</type><mean>0.0</mean><stddev>0.005</stddev></noise></lidar>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <gazebo reference="ir_front_left_link">
    <sensor name="ir_front_left" type="gpu_lidar">
      <pose>0 0 0 0 -1.5707963267949 0</pose>
      <always_on>true</always_on><update_rate>10</update_rate><topic>/ir_front_left/scan</topic>
      <lidar><scan><horizontal><samples>10</samples><resolution>1</resolution><min_angle>-0.30543</min_angle><max_angle>0.30543</max_angle></horizontal><vertical><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></vertical></scan><range><min>0.05</min><max>0.30</max><resolution>0.01</resolution></range><noise><type>gaussian</type><mean>0.0</mean><stddev>0.005</stddev></noise></lidar>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <gazebo reference="ir_left_link">
    <sensor name="ir_left" type="gpu_lidar">
      <pose>0 0 0 0 -1.5707963267949 0</pose>
      <always_on>true</always_on><update_rate>10</update_rate><topic>/ir_left/scan</topic>
      <lidar><scan><horizontal><samples>10</samples><resolution>1</resolution><min_angle>-0.30543</min_angle><max_angle>0.30543</max_angle></horizontal><vertical><samples>1</samples><resolution>1</resolution><min_angle>0</min_angle><max_angle>0</max_angle></vertical></scan><range><min>0.05</min><max>0.30</max><resolution>0.01</resolution></range><noise><type>gaussian</type><mean>0.0</mean><stddev>0.005</stddev></noise></lidar>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

</robot>
