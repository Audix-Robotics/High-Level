  <!-- ============================================================ -->
  <!-- Dummy sensor reference frames (no geometry, fixed to base)   -->
  <!-- Robot frame: X=back, Y=right, Z=up                          -->
  <!-- Sensor Z axis points in the sensing direction                -->
  <!-- ============================================================ -->

  <!-- IR Sensors -->
  <link name="ir_back_link"/>
  <joint name="ir_back_joint" type="fixed">
    <origin xyz="0.00389 -0.15402 0.01325" rpy="0 1.5707963267949 0"/>
    <parent link="base_link"/>
    <child link="ir_back_link"/>
  </joint>

  <link name="ir_right_link"/>
  <joint name="ir_right_joint" type="fixed">
    <origin xyz="-0.15593 0.00425 0.01325" rpy="0 1.5707963267949 1.5707963267949"/>
    <parent link="base_link"/>
    <child link="ir_right_link"/>
  </joint>

  <link name="ir_front_right_link"/>
  <joint name="ir_front_right_joint" type="fixed">
    <origin xyz="-0.33619 -0.02391 0.01325" rpy="0 1.5707963267949 2.3561944901923"/>
    <parent link="base_link"/>
    <child link="ir_front_right_link"/>
  </joint>

  <link name="ir_front_link"/>
  <joint name="ir_front_joint" type="fixed">
    <origin xyz="-0.36061 -0.14597 0.01325" rpy="0 1.5707963267949 3.1415926535898"/>
    <parent link="base_link"/>
    <child link="ir_front_link"/>
  </joint>

  <link name="ir_front_left_link"/>
  <joint name="ir_front_left_joint" type="fixed">
    <origin xyz="-0.34189 -0.27041 0.01325" rpy="0 1.5707963267949 -2.3561944901923"/>
    <parent link="base_link"/>
    <child link="ir_front_left_link"/>
  </joint>

  <link name="ir_left_link"/>
  <joint name="ir_left_joint" type="fixed">
    <origin xyz="-0.16403 -0.30425 0.01325" rpy="0 1.5707963267949 -1.5707963267949"/>
    <parent link="base_link"/>
    <child link="ir_left_link"/>
  </joint>

  <!-- Camera Optical Frame (Z points toward front, i.e. -X direction) -->
  <link name="camera_optical_link"/>
  <joint name="camera_optical_joint" type="fixed">
    <origin xyz="-0.0285214690324131 0.0532714690323321 -0.0320399999999404" rpy="-1.5707963267949 0 -1.57079632679491"/>
    <parent link="camera_link"/>
    <child link="camera_optical_link"/>
  </joint>

  <!-- IMU Frame (aligned with robot body frame) -->
  <link name="imu_link"/>
  <joint name="imu_joint" type="fixed">
    <origin xyz="-0.15866 -0.15079 0.010" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="imu_link"/>
  </joint>

  <!-- ============================================================ -->
  <!-- ros2_control hardware interface                              -->
  <!-- ============================================================ -->
  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="front_left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>
    <joint name="front_right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>
    <joint name="back_left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>
    <joint name="back_right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="velocity"/>
      <state_interface name="position"/>
    </joint>
    <joint name="bottom_stud_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="top_stud_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="left_joint1">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="right_joint1">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="left_joint2">
