  <!-- The remaining gazebo sensor and plugin blocks are unchanged. -->
  <!-- Ensure the gz_ros2_control plugin spawns its controller_manager in the
       requested ROS namespace. Without this <gazebo> plugin block the
       controller_manager appears at /controller_manager (global) which breaks
       namespaced spawners. -->
  <gazebo>
    <plugin filename="libgz_ros2_control-system.so"
            name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <ros>
        <namespace>$(arg robot_namespace)</namespace>
      </ros>
    </plugin>
  </gazebo>
